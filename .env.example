# Tempo Budget - Environment Variables
# Copy this file to .env and fill in the values

# JWT Secret Key (required)
# Generate with: openssl rand -hex 32
JWT_SECRET=c3a65eb91ea0ab0e0e436c4d7d6788fe9fc59160a42c784d820352afdf45481c

# Port to expose (optional, defaults to 80)
PORT=80

# Environment (optional, defaults to production)
ENVIRONMENT=production

# Enable API docs at /docs (optional, defaults to false in production)
DOCS_ENABLED=false

# Stripe (required for subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_monthly_id
STRIPE_PRICE_ANNUAL=price_annual_id

# Stripe price amounts (for display and calculations)
STRIPE_PRICE_MONTHLY_AMOUNT=5.99
STRIPE_PRICE_ANNUAL_AMOUNT=45.0

# Frontend URL (for Stripe redirects)
FRONTEND_URL=http://localhost:5173

# n8n Webhooks (for email notifications)
N8N_WEBHOOK_PAYMENT_CONFIRMATION=https://n8n.example.com/webhook/payment-confirmation
N8N_WEBHOOK_PAYMENT_REMINDER=https://n8n.example.com/webhook/payment-reminder
N8N_WEBHOOK_INVOICE=https://n8n.example.com/webhook/invoice
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret
