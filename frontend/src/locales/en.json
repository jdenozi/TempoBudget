  "help": {
    "title": "Help",
    "openChat": "Open help",
    "welcome": "Hello! I'm here to help. Ask me a question or choose a topic below.",
    "quickTopics": "Common topics",
    "placeholder": "Type your question...",
    "backToTopics": "Back to topics",
    "topics": {
      "invoice": "How do I create an invoice?",
      "quote": "How do I create a quote?",
      "regime": "Which tax regime should I choose?",
      "cotisations": "How are my contributions calculated?",
      "acre": "What is ACRE?",
      "tva": "How does VAT work?",
      "client": "How do I add a client?",
      "declaration": "How do I declare my revenue?"
    },
    "responses": {
      "invoice": "To create an invoice:<br><br>1. Go to <b>Invoices</b> in the menu<br>2. Click <b>New invoice</b><br>3. Select a client (or create one)<br>4. Add your products/services<br>5. Click <b>Save</b><br><br>Your invoices are Factur-X compliant for 2026!",
      "quote": "To create a quote:<br><br>1. Go to <b>Quotes</b> in the menu<br>2. Click <b>New quote</b><br>3. Fill in client info and line items<br>4. Send it to your client<br>5. Once accepted, convert it to an invoice with one click!",
      "regime": "Available tax regimes:<br><br>• <b>Micro-entrepreneur</b>: simple, % of revenue<br>• <b>EI (real regime)</b>: deductible expenses<br>• <b>EURL</b>: company, IR or IS option<br>• <b>SASU/SAS</b>: salaried president<br><br>Use the <b>regime comparison</b> on the dashboard to see which is best for your revenue.",
      "cotisations": "Your contributions are calculated based on your regime:<br><br>• <b>Micro</b>: % of declared revenue (e.g. 21.2% services)<br>• <b>EI/EURL</b>: % of profit (revenue - expenses)<br>• <b>SASU/SAS</b>: charges on your salary<br><br>With ACRE, you get 50% reduction in your first year!",
      "acre": "ACRE (Aid for Business Creators) gives you a <b>50% reduction</b> on social contributions during your first year of business.<br><br>To activate: go to <b>Pro Profile</b> → enable ACRE → enter your business start date.",
      "tva": "As a micro-entrepreneur, you're exempt from VAT if your revenue stays below the thresholds.<br><br>If you're VAT-registered:<br>1. Enable VAT in your profile<br>2. Set your rate (20%, 10%, 5.5%)<br>3. VAT will be calculated on your invoices<br><br>The dashboard shows your collected vs deductible VAT.",
      "client": "To add a client:<br><br>1. Go to <b>Clients</b> in the menu<br>2. Click <b>Add client</b><br>3. Fill in: name, email, address<br>4. For B2B: add SIREN/SIRET for Factur-X<br><br>Your clients will then be available in your invoices and quotes.",
      "declaration": "To declare your revenue:<br><br>1. Go to <b>Accounting</b><br>2. Select the period (month or quarter)<br>3. Check the transactions to declare<br>4. The URSSAF schedule shows deadlines and estimated amounts<br><br>Declare on autoentrepreneur.urssaf.fr with the displayed amounts.",
      "notFound": "I didn't understand your question. Try different keywords or choose a topic from the list above."
    }
  },
